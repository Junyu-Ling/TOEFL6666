{
  "name": "toefl666",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:pronunciation": "node scripts/build-irregular-pronunciation.mjs",
    "build:families": "node scripts/build-word-families.mjs",
    "build:phonetics": "node scripts/build-phonetics.mjs",
    "build:loading-words": "node scripts/build-loading-words.mjs",
    "build:wordlists": "node scripts/build-word-index.mjs && node scripts/build-word-bank.mjs",
    "build": "npm run build:pronunciation && npm run build:families && npm run build:loading-words && npm run build:wordlists && vite build",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@upstash/redis": "^1.38.0",
    "katex": "^0.17.0",
