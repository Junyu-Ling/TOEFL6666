{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/ai/evaluate.js": {
      "maxDuration": 30
    },
    "api/ai/chat.js": {
      "maxDuration": 30
    },
    "api/ai/memory-trick.js": {
      "maxDuration": 30
    },
    "api/sync/push.js": {
      "maxDuration": 15
    },
    "api/sync/pull.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
